{
  "name": "solid-powersync-example",
  "version": "0.0.1",
  "description": "Local-first sync app with PowerSync + SQLite + PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun vike dev",
    "build": "bunx --bun vike build",
    "preview": "NODE_ENV=production bun run dist/server/index.mjs",
    "preview-static": "vite preview",
    "check": "tsc --noemit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "update": "bunx npm-check-updates --format group --interactive",
    "db:migrate": "bun run src/server/database/run-migrations.ts"
  },
  "keywords": [],
  "author": "",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@blankeos/vike-routegen": "^0.0.3",
    "@types/bun": "^1.3.10",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "@journeyapps/wa-sqlite": "^1.0.0",
    "@vikejs/hono": "^0.2.1",
    "@powersync/common": "^1.49.0",
    "@powersync/web": "^1.36.0",
    "@tailwindcss/vite": "^4.2.1",
    "hono": "^4.12.27",
    "jose": "^6.2.1",
    "nanoid": "^5.0.9",
    "postgres": "^3.4.5",
    "solid-js": "1.9.11",
    "vike": "^0.4.260",
    "vike-metadata-solid": "^1.0.5",
    "vike-solid": "^0.8.3"
  }
}
