# ------------------------------------------------------------------------------
# Environment Variables
# 
# PUBLIC_ prefixed vars are exposed to the browser (use sparingly)
# Other vars are server-only and should only be accessed via env.server.ts
# ------------------------------------------------------------------------------

# Client-exposed (PUBLIC_ prefix required)
PUBLIC_BASE_ORIGIN="http://localhost:3000"
PUBLIC_POWERSYNC_URL="http://localhost:8080"

# Server-only (never exposed to browser)
PORT=3000
NODE_ENV="development"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/solid_notes"